<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartGuard.Settings"
        Title="智能电源守护设置"
        Height="640" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="600"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        x:Name="RootWindow">
  <Window.Resources>
    <ResourceDictionary>
      <!-- Theme Colors (Light default) -->
      <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3"/>
      <SolidColorBrush x:Key="WindowForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="NavigationBackground" Color="#F9F9F9"/>
      <SolidColorBrush x:Key="NavigationItemForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="NavigationItemSelectedBackground" Color="#E5E5E5"/>
      <SolidColorBrush x:Key="NavigationItemSelectedForeground" Color="#005FB8"/>
      <SolidColorBrush x:Key="NavigationItemHoverBackground" Color="#EEEEEE"/>
      <SolidColorBrush x:Key="NavigationBorderBrush" Color="#E0E0E0"/>
      <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
      <Color x:Key="CardShadowColor">#20000000</Color>
      <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="TextSecondary" Color="#5C5C5C"/>
      <SolidColorBrush x:Key="TextTertiary" Color="#8A8A8A"/>
      <SolidColorBrush x:Key="TextAccent" Color="#005FB8"/>
      <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#005FB8"/>
      <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="PrimaryButtonHoverBackground" Color="#004578"/>
      <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#D1D1D1"/>
      <SolidColorBrush x:Key="SecondaryButtonHoverBackground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ToggleTrackOff" Color="#C4C4C4"/>
      <SolidColorBrush x:Key="ToggleTrackOn" Color="#005FB8"/>
      <SolidColorBrush x:Key="ToggleThumb" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="NumberBoxBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="NumberBoxBorderBrush" Color="#D1D1D1"/>
      <SolidColorBrush x:Key="NumberBoxButtonBackground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="NumberBoxButtonHoverBackground" Color="#E5E5E5"/>
      <SolidColorBrush x:Key="InfoBarBackground" Color="#E8F3FF"/>
      <SolidColorBrush x:Key="InfoBarForeground" Color="#005FB8"/>
      <SolidColorBrush x:Key="InfoBarBorderBrush" Color="#B3D7F7"/>
      <SolidColorBrush x:Key="DividerBrush" Color="#E5E5E5"/>

      <!-- Navigation Item Style -->
      <Style x:Key="NavigationItemStyle" TargetType="ListBoxItem">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource NavigationItemForeground}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBoxItem">
              <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="4,2">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemSelectedBackground}"/>
                  <Setter Property="Foreground" Value="{DynamicResource NavigationItemSelectedForeground}"/>
                  <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemHoverBackground}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Settings Card Style -->
      <Style x:Key="SettingsCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Effect">
          <Setter.Value>
            <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.06" Color="{DynamicResource CardShadowColor}"/>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Section Title -->
      <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
      </Style>

      <!-- Settings Item Row -->
      <Style x:Key="SettingsItemRow" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,14"/>
        <Setter Property="Margin" Value="0"/>
      </Style>

      <!-- Toggle Switch (CheckBox Template) -->
      <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="CheckBox">
              <Grid VerticalAlignment="Center" HorizontalAlignment="Right">
                <Grid Width="44" Height="24">
                  <Border x:Name="Track" CornerRadius="12" Background="{DynamicResource ToggleTrackOff}"/>
                  <Border x:Name="Thumb" Width="20" Height="20" CornerRadius="10" Background="{DynamicResource ToggleThumb}"
                          HorizontalAlignment="Left" Margin="2,0,0,0"/>
                </Grid>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Track" Property="Background" Value="{DynamicResource ToggleTrackOn}"/>
                  <Setter TargetName="Thumb" Property="Margin" Value="22,0,0,0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Track" Property="Opacity" Value="0.5"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
      </Style>

      <!-- Primary Button -->
      <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForeground}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryButtonHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="bd" Property="RenderTransform">
                    <Setter.Value>
                      <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Secondary Button -->
      <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForeground}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="bd" Property="Background" Value="{DynamicResource SecondaryButtonHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="bd" Property="RenderTransform">
                    <Setter.Value>
                      <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- NumberBox Style -->
      <Style TargetType="local:NumberBox">
        <Setter Property="Width" Value="120"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="local:NumberBox">
              <Border Background="{DynamicResource NumberBoxBackground}" BorderBrush="{DynamicResource NumberBoxBorderBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="PART_TextBox" Grid.Column="0" BorderThickness="0" Background="Transparent"
                           Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                           Padding="4,0"/>
                  <Button Grid.Column="1" Content="-" Command="{TemplateBinding DecrementCommand}"
                          Background="{DynamicResource NumberBoxButtonBackground}" BorderThickness="0"
                          FontSize="14" FontWeight="Bold" Cursor="Hand">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="Button">
                              <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                              </Border>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </Button.Style>
                  </Button>
                  <Button Grid.Column="2" Content="+" Command="{TemplateBinding IncrementCommand}"
                          Background="{DynamicResource NumberBoxButtonBackground}" BorderThickness="0"
                          FontSize="14" FontWeight="Bold" Cursor="Hand">
                    <Button.Style>
                      <Style TargetType="Button">
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="Button">
                              <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                              </Border>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </Style>
                    </Button.Style>
                  </Button>
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- InfoBar Style -->
      <Style x:Key="InfoBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource InfoBarBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Visibility" Value="Collapsed"/>
      </Style>

      <!-- Theme Toggle Button -->
      <Style x:Key="ThemeToggleButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="{DynamicResource NavigationItemHoverBackground}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Left Navigation Panel -->
    <Border Grid.Column="0" Background="{DynamicResource NavigationBackground}" BorderBrush="{DynamicResource NavigationBorderBrush}" BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- App Header -->
        <StackPanel Grid.Row="0" Margin="20,24,20,16">
          <TextBlock Text="智能电源守护" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
          <TextBlock Text="设置" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Navigation Items -->
        <ListBox Grid.Row="1" x:Name="navList" BorderThickness="0" Background="Transparent"
                 ItemContainerStyle="{StaticResource NavigationItemStyle}" Margin="8,0">
          <ListBoxItem x:Name="navGeneral" IsSelected="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="常规" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navAdvanced">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9A6;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="高级" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navNotifications">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xEA8F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="通知" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
        </ListBox>

        <!-- Theme Toggle -->
        <Button Grid.Row="2" x:Name="btnThemeToggle" Style="{StaticResource ThemeToggleButton}" Margin="16,8,16,16"
                HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="iconTheme" Text="&#xE706;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,8,0"/>
            <TextBlock x:Name="txtTheme" Text="深色模式" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Right Content Area -->
    <Grid Grid.Column="1" Background="{DynamicResource WindowBackground}">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Content Pages -->
      <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,20,24,12">
        <StackPanel>

          <!-- General Page -->
          <StackPanel x:Name="pageGeneral">
            <TextBlock Text="常规设置" Style="{StaticResource SectionTitle}"/>

            <!-- System Card -->
            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="系统" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="管理开机启动和基本系统行为" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="开机自启动" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="启动 Core 和托盘程序" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="tglAutoStart" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <!-- Idle & Battery Card -->
            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="空闲与电池" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="自动切换电源计划的空闲时间和电池阈值" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="空闲后切换平衡" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="空闲多久后切换到平衡计划（分钟）" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBalanced" Text="5 分钟" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBalanced" Minimum="1" Maximum="120" SmallChange="1"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="空闲后切换节能" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="空闲多久后切换到节能计划（分钟）" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblSaver" Text="15 分钟" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldSaver" Minimum="2" Maximum="240" SmallChange="1"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="低电量阈值" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="低于此百分比时触发保护（%）" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBattery" Text="30%" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBattery" Minimum="0" Maximum="100" SmallChange="5"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Advanced Page -->
          <StackPanel x:Name="pageAdvanced" Visibility="Collapsed">
            <TextBlock Text="高级设置" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="运行参数" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="调整引擎轮询频率和亮度恢复延迟" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="轮询间隔" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="引擎检查系统状态的频率（秒）" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblPoll" Text="15 秒" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldPoll" Minimum="5" Maximum="120" SmallChange="5"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="亮度恢复延迟" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="从节能恢复后延迟恢复亮度（毫秒）" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBrightMs" Text="500 毫秒" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBrightMs" Minimum="0" Maximum="3000" SmallChange="50"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Notifications Page -->
          <StackPanel x:Name="pageNotifications" Visibility="Collapsed">
            <TextBlock Text="通知设置" Style="{StaticResource SectionTitle}"/>

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="通知与守护" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Text="控制通知行为和守护模式" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="暂停守护" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="仅监控状态，不自动切换电源计划" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="tglPaused" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="计划变更通知" FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="切换电源计划时弹出系统通知" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="tglNotify" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>

      <!-- InfoBar -->
      <Border Grid.Row="1" x:Name="infoBar" Style="{StaticResource InfoBar}" Margin="24,0,24,0">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16"
                     Foreground="{DynamicResource InfoBarForeground}" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock x:Name="txtInfoBar" Text="保存后立即生效" Foreground="{DynamicResource InfoBarForeground}"/>
        </StackPanel>
      </Border>

      <!-- Bottom Action Bar -->
      <Border Grid.Row="2" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource DividerBrush}"
              BorderThickness="0,1,0,0" Padding="24,16">
        <Grid>
          <TextBlock Text="保存后立即生效" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Content="取消" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <Button x:Name="btnSave" Content="保存" Style="{StaticResource PrimaryButton}" IsDefault="True"/>
          </StackPanel>
        </Grid>
      </Border>
