<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SmartGuard.Settings"
        Title="智能电源守护设置"
        Height="640" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="600"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI, Segoe UI Variable, Segoe UI"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        x:Name="RootWindow">
  <Window.Resources>
    <ResourceDictionary>
      <!-- Theme Colors (Light default) -->
      <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3"/>
      <SolidColorBrush x:Key="WindowForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="NavigationBackground" Color="#F9F9F9"/>
      <SolidColorBrush x:Key="NavigationItemForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="NavigationItemSelectedBackground" Color="#E5E5E5"/>
      <SolidColorBrush x:Key="NavigationItemSelectedForeground" Color="#005FB8"/>
      <SolidColorBrush x:Key="NavigationItemHoverBackground" Color="#EEEEEE"/>
      <SolidColorBrush x:Key="NavigationBorderBrush" Color="#E0E0E0"/>
      <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
      <Color x:Key="CardShadowColor">#20000000</Color>
      <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="TextSecondary" Color="#616161"/>
      <SolidColorBrush x:Key="TextTertiary" Color="#8A8A8A"/>
      <SolidColorBrush x:Key="TextAccent" Color="#005FB8"/>
      <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#005FB8"/>
      <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="PrimaryButtonHoverBackground" Color="#004578"/>
      <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#D1D1D1"/>
      <SolidColorBrush x:Key="SecondaryButtonHoverBackground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ToggleTrackOff" Color="#C4C4C4"/>
      <SolidColorBrush x:Key="ToggleTrackOn" Color="#005FB8"/>
      <SolidColorBrush x:Key="ToggleThumb" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="NumberBoxBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="NumberBoxBorderBrush" Color="#D1D1D1"/>
      <SolidColorBrush x:Key="NumberBoxButtonBackground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="NumberBoxButtonHoverBackground" Color="#E5E5E5"/>
      <SolidColorBrush x:Key="InfoBarBackground" Color="#E8F3FF"/>
      <SolidColorBrush x:Key="InfoBarForeground" Color="#005FB8"/>
      <SolidColorBrush x:Key="InfoBarBorderBrush" Color="#B3D7F7"/>
      <SolidColorBrush x:Key="DividerBrush" Color="#E5E5E5"/>
      <Thickness x:Key="SettingsContentPageMargin">24,24,24,12</Thickness>
      <Thickness x:Key="ToastContainerMargin">0,72,24,0</Thickness>

      <!-- Navigation Item Style -->
      <Style x:Key="NavigationItemStyle" TargetType="ListBoxItem">
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="16,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource NavigationItemForeground}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBoxItem">
              <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Margin="0">
                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="{TemplateBinding Padding}"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemSelectedBackground}"/>
                  <Setter Property="Foreground" Value="{DynamicResource NavigationItemSelectedForeground}"/>
                  <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemHoverBackground}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Settings Card Style -->
      <Style x:Key="SettingsCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20,16"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
      </Style>

      <!-- Section Title -->
      <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
      </Style>

      <!-- Card group title (within settings cards) -->
      <Style x:Key="SettingsGroupTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
      </Style>

      <!-- Card group description -->
      <Style x:Key="SettingsCardDescription" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
      </Style>

      <!-- Setting item primary label -->
      <Style x:Key="SettingsItemTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
      </Style>

      <!-- Setting item hint text below label -->
      <Style x:Key="SettingsItemHint" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="LineHeight" Value="18"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
      </Style>

      <!-- Settings Item Row -->
      <Style x:Key="SettingsItemRow" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,14"/>
        <Setter Property="Margin" Value="0"/>
      </Style>

      <!-- Toggle Switch (CheckBox Template) -->
      <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="CheckBox">
              <Grid VerticalAlignment="Center" HorizontalAlignment="Right">
                <Grid Width="44" Height="24">
                  <Border x:Name="Track" CornerRadius="12" Background="{DynamicResource ToggleTrackOff}"/>
                  <Border x:Name="Thumb" Width="20" Height="20" CornerRadius="10" Background="{DynamicResource ToggleThumb}"
                          HorizontalAlignment="Left" Margin="2,0,0,0"/>
                </Grid>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="Track" Property="Background" Value="{DynamicResource ToggleTrackOn}"/>
                  <Setter TargetName="Thumb" Property="Margin" Value="22,0,0,0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Track" Property="Opacity" Value="0.5"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
      </Style>

      <!-- Primary Button -->
      <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForeground}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryButtonHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="bd" Property="RenderTransform">
                    <Setter.Value>
                      <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Secondary Button -->
      <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForeground}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SecondaryButtonBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="bd" Property="Background" Value="{DynamicResource SecondaryButtonHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="bd" Property="RenderTransform">
                    <Setter.Value>
                      <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                    </Setter.Value>
                  </Setter>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Compact toolbar button (log page) -->
      <Style x:Key="LogToolbarCompactButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
      </Style>

      <!-- NumberBox increment/decrement button (must be defined before NumberBox template) -->
      <Style x:Key="NumberBoxButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource NumberBoxButtonBackground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NumberBoxButtonHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- NumberBox Style -->
      <Style TargetType="local:NumberBox">
        <Setter Property="Width" Value="120"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="local:NumberBox">
              <Border Background="{DynamicResource NumberBoxBackground}" BorderBrush="{DynamicResource NumberBoxBorderBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="PART_TextBox" Grid.Column="0" BorderThickness="0" Background="Transparent"
                           Foreground="{DynamicResource TextPrimary}" CaretBrush="{DynamicResource TextPrimary}"
                           Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                           VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                           Padding="4,0"/>
                  <Button Grid.Column="1" Content="-" Command="{TemplateBinding DecrementCommand}"
                          Style="{StaticResource NumberBoxButton}" FontSize="14" FontWeight="Bold"/>
                  <Button Grid.Column="2" Content="+" Command="{TemplateBinding IncrementCommand}"
                          Style="{StaticResource NumberBoxButton}" FontSize="14" FontWeight="Bold"/>
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Fluent TextBox -->
      <Style x:Key="SettingsTextBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource NumberBoxBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NumberBoxBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource TextAccent}"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="TextBox">
              <Border x:Name="Bd"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="4">
                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                  <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextAccent}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.6"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="SettingsTextBoxBorderless" TargetType="TextBox" BasedOn="{StaticResource SettingsTextBox}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="0"/>
      </Style>

      <!-- Fluent Hyperlink -->
      <Style TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{DynamicResource TextAccent}"/>
        <Setter Property="TextDecorations" Value="None"/>
        <Style.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="TextDecorations" Value="Underline"/>
          </Trigger>
        </Style.Triggers>
      </Style>

      <!-- Fluent ScrollBar -->
      <Style x:Key="SettingsScrollBar" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
              <Grid Background="Transparent">
                <Track x:Name="PART_Track">
                  <Track.Style>
                    <Style TargetType="Track">
                      <Setter Property="IsDirectionReversed" Value="False"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource TemplatedParent}}" Value="Vertical">
                          <Setter Property="IsDirectionReversed" Value="True"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Track.Style>
                  <Track.Thumb>
                    <Thumb>
                      <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                          <Border Background="{DynamicResource TextTertiary}" CornerRadius="4" Opacity="0.55"/>
                        </ControlTemplate>
                      </Thumb.Template>
                    </Thumb>
                  </Track.Thumb>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
        <Style.Triggers>
          <Trigger Property="Orientation" Value="Horizontal">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="MinHeight" Value="8"/>
          </Trigger>
        </Style.Triggers>
      </Style>

      <Style x:Key="SettingsScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ScrollViewer">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollContentPresenter Grid.Row="0" Grid.Column="0" Margin="{TemplateBinding Padding}"/>
                <ScrollBar x:Name="PART_VerticalScrollBar"
                           Grid.Row="0"
                           Grid.Column="1"
                           Style="{StaticResource SettingsScrollBar}"
                           Value="{TemplateBinding VerticalOffset}"
                           Maximum="{TemplateBinding ScrollableHeight}"
                           ViewportSize="{TemplateBinding ViewportHeight}"
                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                           HorizontalAlignment="Right"/>
                <ScrollBar x:Name="PART_HorizontalScrollBar"
                           Grid.Row="1"
                           Grid.Column="0"
                           Style="{StaticResource SettingsScrollBar}"
                           Orientation="Horizontal"
                           Value="{TemplateBinding HorizontalOffset}"
                           Maximum="{TemplateBinding ScrollableWidth}"
                           ViewportSize="{TemplateBinding ViewportWidth}"
                           Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                           VerticalAlignment="Bottom"/>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="SettingsLogListBox" TargetType="ListBox">
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ListBox">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}">
                <ScrollViewer Style="{StaticResource SettingsScrollViewer}"
                              Focusable="False"
                              CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                              Padding="{TemplateBinding Padding}">
                  <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                </ScrollViewer>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Settings ComboBox -->
      <Style x:Key="SettingsComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource NumberBoxBackground}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ComboBoxItem">
              <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                <ContentPresenter/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                  <Setter TargetName="Bd" Property="Background" Value="{DynamicResource NavigationItemSelectedBackground}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <Style x:Key="SettingsComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItem}"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="ComboBox">
              <Grid SnapsToDevicePixels="True">
                <ToggleButton x:Name="ToggleButton"
                              Focusable="False"
                              Background="Transparent"
                              BorderThickness="0"
                              OverridesDefaultStyle="True"
                              FocusVisualStyle="{x:Null}"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press">
                  <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                      <Border x:Name="Bd"
                              Background="{DynamicResource NumberBoxBackground}"
                              BorderBrush="{DynamicResource NumberBoxBorderBrush}"
                              BorderThickness="1"
                              CornerRadius="4">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                          </Grid.ColumnDefinitions>
                          <ContentPresenter Grid.Column="0" Margin="8,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                          <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextAccent}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                          <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextAccent}"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </ToggleButton.Template>
                </ToggleButton>
                <ContentPresenter x:Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  Margin="8,0,28,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"/>
                <Popup x:Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                  <Border Background="{DynamicResource NumberBoxBackground}"
                          BorderBrush="{DynamicResource NumberBoxBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="4"
                          MinWidth="{TemplateBinding ActualWidth}"
                          MaxHeight="240">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                  </Border>
                </Popup>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- Filter checkbox (log page and inline options) -->
      <Style x:Key="SettingsFilterCheckBox" TargetType="CheckBox">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="CheckBox">
              <StackPanel Orientation="Horizontal">
                <Border x:Name="Box" Width="16" Height="16" CornerRadius="3"
                        BorderBrush="{DynamicResource NumberBoxBorderBrush}" BorderThickness="1"
                        Background="{DynamicResource NumberBoxBackground}" Margin="0,0,6,0">
                  <TextBlock x:Name="CheckMark" Text="✓" FontSize="11" FontWeight="Bold"
                             Foreground="{DynamicResource TextAccent}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                </Border>
                <ContentPresenter VerticalAlignment="Center"/>
              </StackPanel>
              <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                  <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                  <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource TextAccent}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Box" Property="Background" Value="{DynamicResource NumberBoxButtonHoverBackground}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>

      <!-- InfoBar Style -->
      <Style x:Key="InfoBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource InfoBarBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InfoBarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Visibility" Value="Collapsed"/>
      </Style>

      <!-- Default Fluent styles for common controls (explicit styles remain on toggles/buttons) -->
      <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource SettingsTextBox}"/>
      <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource SettingsComboBox}"/>

    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Left Navigation Panel -->
    <Border Grid.Column="0" Background="{DynamicResource NavigationBackground}" BorderBrush="{DynamicResource NavigationBorderBrush}" BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- App Header -->
        <StackPanel Grid.Row="0" Margin="20,24,20,16" Orientation="Horizontal">
          <Image x:Name="imgAppIcon" Width="24" Height="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
          <TextBlock Text="智能电源守护" FontSize="18" FontWeight="SemiBold"
                     VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
        </StackPanel>

        <!-- Navigation Items -->
        <ListBox Grid.Row="1" x:Name="navList" BorderThickness="0" Background="Transparent"
                 FocusVisualStyle="{x:Null}"
                 ItemContainerStyle="{StaticResource NavigationItemStyle}" Margin="8,0">
          <ListBoxItem x:Name="navGeneral" IsSelected="True">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="常规" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navAdvanced">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9A6;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="高级" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navNotifications">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="通知" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navLogs">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="日志" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navDisplay">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE793;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="显示" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
          <ListBoxItem x:Name="navAbout">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
              <TextBlock Text="关于" VerticalAlignment="Center"/>
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </Grid>
    </Border>

    <!-- Right Content Area -->
    <Grid x:Name="rightContentRoot" Grid.Column="1" Background="{DynamicResource WindowBackground}" Margin="{StaticResource SettingsContentPageMargin}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock x:Name="txtPageTitle" Grid.Row="0" Text="常规设置" Style="{StaticResource SectionTitle}"/>

      <!-- Content Pages -->
      <ScrollViewer x:Name="contentScrollViewer" Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Style="{StaticResource SettingsScrollViewer}" HorizontalContentAlignment="Stretch" local:ScrollBarAutoHide.IsEnabled="True">
        <StackPanel HorizontalAlignment="Stretch">

          <!-- General Page -->
          <StackPanel x:Name="pageGeneral" HorizontalAlignment="Stretch">

            <!-- System Card -->
            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="系统" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="管理开机启动和基本系统行为" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="开机自启动" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="启动 Core 和托盘程序" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglAutoStart" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <!-- Idle & Battery Card -->
            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="空闲与电池" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="自动切换电源计划的空闲时间和电池阈值" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="空闲后切换平衡" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="空闲多久后切换到平衡计划（分钟）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBalanced" Text="5 分钟" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBalanced" Minimum="1" Maximum="120" SmallChange="1"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="空闲后切换节能" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="空闲多久后切换到节能计划（分钟）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblSaver" Text="15 分钟" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldSaver" Minimum="2" Maximum="240" SmallChange="1"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="低电量阈值" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="低于此百分比时触发保护（%）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBattery" Text="30%" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBattery" Minimum="0" Maximum="100" SmallChange="5"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Advanced Page -->
          <StackPanel x:Name="pageAdvanced" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="运行参数" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="调整引擎轮询频率、心跳日志和亮度恢复延迟" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="轮询间隔" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="引擎检查系统状态的频率（秒）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblPoll" Text="15 秒" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldPoll" Minimum="5" Maximum="120" SmallChange="5"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                      <TextBlock Text="心跳日志间隔" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="无事件时，每隔多久写入一条 HEART 状态日志" Style="{StaticResource SettingsItemHint}"/>
                      <TextBlock Text="（分钟；0 表示关闭）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblHeartbeat" Text="10 分钟" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldHeartbeat" Minimum="0" Maximum="1440" SmallChange="1"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="亮度恢复延迟" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="从节能恢复后延迟恢复亮度（毫秒）" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <TextBlock x:Name="lblBrightMs" Text="500 毫秒" Foreground="{DynamicResource TextAccent}" FontWeight="SemiBold"
                                 VerticalAlignment="Center" Margin="0,0,12,0"/>
                      <local:NumberBox x:Name="sldBrightMs" Minimum="0" Maximum="3000" SmallChange="50"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="电源计划映射" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="选择 SmartGuard 三档策略分别对应的 Windows 电源计划" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="高性能" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="活跃状态下使用的电源计划" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbActivePlan" Grid.Column="1" Width="240" MinWidth="180" Style="{StaticResource SettingsComboBox}"/>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="平衡" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="空闲一段时间后切换到的电源计划" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbBalancedPlan" Grid.Column="1" Width="240" MinWidth="180" Style="{StaticResource SettingsComboBox}"/>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="节能" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="深度空闲或低电量时使用的电源计划" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <ComboBox x:Name="cmbPowerSaverPlan" Grid.Column="1" Width="240" MinWidth="180" Style="{StaticResource SettingsComboBox}"/>
                  </Grid>
                </Border>

                <TextBlock x:Name="lblPlanMappingStatus" Text="" Style="{StaticResource SettingsItemHint}" Margin="0,8,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Notifications Page -->
          <StackPanel x:Name="pageNotifications" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="通知与守护" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="控制通知行为和守护模式" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="暂停守护" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="仅监控状态，不自动切换电源计划" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglPaused" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="自动切换通知" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="SmartGuard 切换电源计划时弹出系统通知" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglNotify" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="外部变更通知" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="检测到计划被外部修改时弹出系统通知" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglNotifyExternal" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- Display Page -->
          <StackPanel x:Name="pageDisplay" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="外观" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="选择界面配色方案" Style="{StaticResource SettingsCardDescription}"/>

                <Border x:Name="rowThemeFollowSystem" Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="跟随系统" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="自动匹配 Windows 浅色或深色模式" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglThemeFollowSystem" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>

                <Border x:Name="rowThemeLight" Style="{StaticResource SettingsItemRow}" Visibility="Collapsed">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="浅色模式" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="使用浅色界面配色" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglThemeLight" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>

                <Border x:Name="rowThemeDark" Style="{StaticResource SettingsItemRow}" BorderThickness="0" Visibility="Collapsed">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="深色模式" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="使用深色界面配色" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <CheckBox x:Name="tglThemeDark" Grid.Column="1" Style="{StaticResource ToggleSwitch}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>

          <!-- About Page -->
          <StackPanel x:Name="pageAbout" Visibility="Collapsed" HorizontalAlignment="Stretch">

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="SmartGuard" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="智能电源守护" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="版本" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock x:Name="txtVersion" Text="1.0.0" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="仓库地址" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Style="{StaticResource SettingsItemHint}">
                        <Hyperlink x:Name="lnkRepo" NavigateUri="https://github.com/rainiva/SmartGuard">
                          https://github.com/rainiva/SmartGuard
                        </Hyperlink>
                      </TextBlock>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="更新" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="检查是否有新版本可用" Style="{StaticResource SettingsItemHint}"/>
                    </StackPanel>
                    <Button x:Name="btnCheckUpdate" Grid.Column="1" Content="检查更新" Style="{StaticResource PrimaryButton}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
              <StackPanel>
                <TextBlock Text="维护" Style="{StaticResource SettingsGroupTitle}"/>
                <TextBlock Text="配置异常时可恢复默认策略" Style="{StaticResource SettingsCardDescription}"/>

                <Border Style="{StaticResource SettingsItemRow}" BorderThickness="0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="恢复默认策略" Style="{StaticResource SettingsItemTitle}"/>
                      <TextBlock Text="重置阈值与计划映射；保留日志路径和 GitHub Token" Style="{StaticResource SettingsItemHint}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Name="btnResetDefaults" Grid.Column="1" Content="恢复默认" Style="{StaticResource SecondaryButton}"/>
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>


        </StackPanel>
      </ScrollViewer>

      <!-- Logs Page -->
      <!-- Kept outside contentScrollViewer so the log area is the only scrollable region on this page. -->
      <Grid x:Name="pageLogs" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Style="{StaticResource SettingsCard}" VerticalAlignment="Stretch">
          <Grid VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Fixed Header: Title, Description, Search, Filters -->
            <StackPanel Grid.Row="0">
              <TextBlock Text="实时日志" Style="{StaticResource SettingsGroupTitle}"/>
              <TextBlock Text="查看 SmartGuard 运行日志，支持搜索和筛选" Style="{StaticResource SettingsCardDescription}"/>

              <!-- Search Bar with tag filter chips -->
              <Border Background="{DynamicResource NumberBoxBackground}" BorderBrush="{DynamicResource NumberBoxBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,12">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource TextTertiary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                  <ContentControl x:Name="logSearchFilterHost" Grid.Column="1" VerticalAlignment="Center"/>
                </Grid>
              </Border>

              <!-- Unified filter + action toolbar -->
              <Border x:Name="logToolbarPanel"
                      Background="{DynamicResource NumberBoxBackground}"
                      BorderBrush="{DynamicResource NumberBoxBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="4"
                      Padding="12,10"
                      Margin="0,0,0,12">
                <StackPanel>
                  <WrapPanel x:Name="logFilterLevelPanel" Margin="0,0,0,8">
                    <TextBlock Text="标签" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,6"/>
                    <WrapPanel x:Name="logTagFilterLinksPanel"/>
                  </WrapPanel>

                  <WrapPanel x:Name="logFilterTimePanel">
                    <TextBlock Text="时间" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <ComboBox x:Name="cmbLogTimeRange" Width="120" SelectedIndex="0" Margin="0,0,12,6" Style="{StaticResource SettingsComboBox}">
                      <ComboBoxItem Content="全部"/>
                      <ComboBoxItem Content="今天"/>
                      <ComboBoxItem Content="最近1小时"/>
                      <ComboBoxItem Content="自定义"/>
                    </ComboBox>
                    <CheckBox x:Name="chkLogSearchCaseSensitive" Content="区分大小写" Style="{StaticResource SettingsFilterCheckBox}" Margin="0,0,0,6"/>
                  </WrapPanel>

                  <StackPanel x:Name="panelLogCustomRange" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                    <TextBlock Text="起" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="txtLogRangeStart" Width="160" FontSize="12" Foreground="{DynamicResource TextPrimary}" ToolTip="yyyy-MM-dd HH:mm:ss"/>
                    <TextBlock Text="止" FontSize="12" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <TextBox x:Name="txtLogRangeEnd" Width="160" FontSize="12" Foreground="{DynamicResource TextPrimary}" ToolTip="yyyy-MM-dd HH:mm:ss"/>
                  </StackPanel>

                  <Border x:Name="logToolbarDivider" Height="1" Background="{DynamicResource DividerBrush}" Margin="0,10,0,10"/>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel Grid.Column="0" Margin="0,0,8,0">
                      <Button x:Name="btnLogCopy" Content="复制可见" Style="{StaticResource LogToolbarCompactButton}" Margin="0,0,6,6"/>
                      <Button x:Name="btnLogExport" Content="导出" Style="{StaticResource LogToolbarCompactButton}" Margin="0,0,6,6"/>
                      <Button x:Name="btnLogOpenFolder" Content="打开目录" Style="{StaticResource LogToolbarCompactButton}" Margin="0,0,6,6"/>
                      <Button x:Name="btnLogScrollTop" Content="顶部" Style="{StaticResource LogToolbarCompactButton}" Margin="0,0,6,6"/>
                      <Button x:Name="btnLogScrollBottom" Content="底部" Style="{StaticResource LogToolbarCompactButton}" Margin="0,0,0,6"/>
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                      <CheckBox x:Name="chkLogFollowTail" Content="跟随最新" IsChecked="True" Style="{StaticResource SettingsFilterCheckBox}" Margin="0,0,10,0"/>
                      <Button x:Name="btnLogRefresh" Content="刷新" Style="{StaticResource LogToolbarCompactButton}"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Scrollable Log Content -->
            <Border x:Name="logViewportBorder"
                    Grid.Row="1"
                    Background="{DynamicResource NumberBoxBackground}"
                    BorderBrush="{DynamicResource NumberBoxBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    ClipToBounds="True"
                    VerticalAlignment="Stretch">
              <ListBox x:Name="lstLogView"
                       Style="{StaticResource SettingsLogListBox}"
                       VirtualizingPanel.IsVirtualizing="True"
                       VirtualizingPanel.VirtualizationMode="Recycling"
                       BorderThickness="0"
                       Background="Transparent"
                       Padding="12"
                       FontFamily="Consolas, Microsoft YaHei Mono"
                       FontSize="12"
                       VerticalAlignment="Stretch"/>
            </Border>

            <!-- Status Bar (outside scrollable area, stays visible) -->
            <TextBlock x:Name="lblLogStatus" Text="暂无日志" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,8,0,0" Grid.Row="2"/>
          </Grid>
        </Border>
      </Grid>

      <!-- Settings are applied instantly; no bottom action bar is needed. -->
    </Grid>

    <!-- Inline toast overlay -->
    <Border x:Name="toastContainer"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="{StaticResource ToastContainerMargin}"
            Visibility="Collapsed"
            Background="Transparent"
            BorderThickness="0"
            ClipToBounds="False"
            Panel.ZIndex="100"/>
  </Grid>
</Window>