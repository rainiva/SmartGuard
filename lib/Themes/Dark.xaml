<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Window -->
  <SolidColorBrush x:Key="WindowBackground" Color="#202020"/>
  <SolidColorBrush x:Key="WindowForeground" Color="#FFFFFF"/>

  <!-- Navigation -->
  <SolidColorBrush x:Key="NavigationBackground" Color="#1C1C1C"/>
  <SolidColorBrush x:Key="NavigationItemForeground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="NavigationItemSelectedBackground" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="NavigationItemSelectedForeground" Color="#4CC2FF"/>
  <SolidColorBrush x:Key="NavigationItemHoverBackground" Color="#2A2A2A"/>
  <SolidColorBrush x:Key="NavigationBorderBrush" Color="#3A3A3A"/>

  <!-- Card -->
  <SolidColorBrush x:Key="CardBackground" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3A3A"/>
  <SolidColorBrush x:Key="CardShadowColor" Color="#40000000"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
  <SolidColorBrush x:Key="TextTertiary" Color="#8A8A8A"/>
  <SolidColorBrush x:Key="TextAccent" Color="#4CC2FF"/>

  <!-- Controls -->
  <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#4CC2FF"/>
  <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#1A1A1A"/>
  <SolidColorBrush x:Key="PrimaryButtonHoverBackground" Color="#3AA8E0"/>
  <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#5A5A5A"/>
  <SolidColorBrush x:Key="SecondaryButtonHoverBackground" Color="#3A3A3A"/>

  <SolidColorBrush x:Key="ToggleTrackOff" Color="#5A5A5A"/>
  <SolidColorBrush x:Key="ToggleTrackOn" Color="#4CC2FF"/>
  <SolidColorBrush x:Key="ToggleThumb" Color="#FFFFFF"/>

  <SolidColorBrush x:Key="NumberBoxBackground" Color="#2D2D2D"/>
  <SolidColorBrush x:Key="NumberBoxBorderBrush" Color="#5A5A5A"/>
  <SolidColorBrush x:Key="NumberBoxButtonBackground" Color="#3A3A3A"/>
  <SolidColorBrush x:Key="NumberBoxButtonHoverBackground" Color="#4A4A4A"/>

  <SolidColorBrush x:Key="InfoBarBackground" Color="#1A3A5C"/>
  <SolidColorBrush x:Key="InfoBarForeground" Color="#4CC2FF"/>
  <SolidColorBrush x:Key="InfoBarBorderBrush" Color="#2A5A8A"/>

  <SolidColorBrush x:Key="DividerBrush" Color="#3A3A3A"/>

</ResourceDictionary>
