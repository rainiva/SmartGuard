<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Window -->
  <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3"/>
  <SolidColorBrush x:Key="WindowForeground" Color="#1A1A1A"/>

  <!-- Navigation -->
  <SolidColorBrush x:Key="NavigationBackground" Color="#F9F9F9"/>
  <SolidColorBrush x:Key="NavigationItemForeground" Color="#1A1A1A"/>
  <SolidColorBrush x:Key="NavigationItemSelectedBackground" Color="#E5E5E5"/>
  <SolidColorBrush x:Key="NavigationItemSelectedForeground" Color="#005FB8"/>
  <SolidColorBrush x:Key="NavigationItemHoverBackground" Color="#EEEEEE"/>
  <SolidColorBrush x:Key="NavigationBorderBrush" Color="#E0E0E0"/>

  <!-- Card -->
  <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
  <SolidColorBrush x:Key="CardShadowColor" Color="#20000000"/>

  <!-- Text -->
  <SolidColorBrush x:Key="TextPrimary" Color="#1A1A1A"/>
  <SolidColorBrush x:Key="TextSecondary" Color="#616161"/>
  <SolidColorBrush x:Key="TextTertiary" Color="#8A8A8A"/>
  <SolidColorBrush x:Key="TextAccent" Color="#005FB8"/>

  <!-- Controls -->
  <SolidColorBrush x:Key="PrimaryButtonBackground" Color="#005FB8"/>
  <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="PrimaryButtonHoverBackground" Color="#004578"/>
  <SolidColorBrush x:Key="SecondaryButtonBackground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SecondaryButtonForeground" Color="#1A1A1A"/>
  <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#D1D1D1"/>
  <SolidColorBrush x:Key="SecondaryButtonHoverBackground" Color="#F0F0F0"/>

  <SolidColorBrush x:Key="ToggleTrackOff" Color="#C4C4C4"/>
  <SolidColorBrush x:Key="ToggleTrackOn" Color="#005FB8"/>
  <SolidColorBrush x:Key="ToggleThumb" Color="#FFFFFF"/>

  <SolidColorBrush x:Key="NumberBoxBackground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="NumberBoxBorderBrush" Color="#D1D1D1"/>
  <SolidColorBrush x:Key="NumberBoxButtonBackground" Color="#F0F0F0"/>
  <SolidColorBrush x:Key="NumberBoxButtonHoverBackground" Color="#E5E5E5"/>

  <SolidColorBrush x:Key="InfoBarBackground" Color="#E8F3FF"/>
  <SolidColorBrush x:Key="InfoBarForeground" Color="#005FB8"/>
  <SolidColorBrush x:Key="InfoBarBorderBrush" Color="#B3D7F7"/>

  <SolidColorBrush x:Key="DividerBrush" Color="#E5E5E5"/>

</ResourceDictionary>
